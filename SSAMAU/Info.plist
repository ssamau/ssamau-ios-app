<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>SSAMAU</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ar</string>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>Almarai-Light.ttf</string>
		<string>Almarai-Regular.ttf</string>
		<string>Almarai-Bold.ttf</string>
		<string>Almarai-ExtraBold.ttf</string>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>app-prefs</string>
		<string>app-settings</string>
	</array>
	<!-- Photo library: ProfileView avatar upload + SupportSubmitSheet
	     screenshot attachment. Read-only — we never write back to the
	     library, just read the user-picked image once. PhotosPicker on
	     iOS 16+ uses a sandboxed picker so the system also enforces
	     "user-picked only" outside of our usage description. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SSAMAU uses your photo library to upload a profile picture or attach a screenshot to a support ticket. Photos are only read when you explicitly pick them.</string>
	<!-- Skip the App Store export-compliance prompt: this build uses
	     only Apple-standard https / TLS, which is exempt under
	     §740.17(b) of the EAR (ENC). Flip to true (and submit the
	     relevant docs) if we ever ship custom crypto. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Branded launch screen: cream background + the SSAM logo
	     centered. Xcode's auto-generated launch screen is a plain
	     white screen which looks abrupt against the green/gold
	     brand. UILaunchScreen lets us style without a storyboard. -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>Cream</string>
		<key>UIImageName</key>
		<string>SSAMLogo</string>
		<key>UIImageRespectsSafeAreaInsets</key>
		<true/>
	</dict>
	<!-- Multi-window support (iPad Split View / Slide Over / two
	     instances side by side, and separate Mac windows under
	     Catalyst). Pure SwiftUI lifecycle: the @main App's WindowGroup
	     vends each scene, so no UISceneConfigurations / SceneDelegate
	     entries are needed — SupportsMultipleScenes = true is enough
	     for SwiftUI to allow new windows.

	     Each scene instantiates RootView fresh, so per-window
	     navigation state (sidebar selection, nav paths) is independent,
	     while SessionStore.shared is injected into every scene as the
	     same instance so auth / signed-in user is shared. A head can
	     open two windows and drive each committee view independently
	     without re-logging in.

	     INFOPLIST_KEY_UIApplicationSceneManifest_Generation is set to
	     NO in build settings so this explicit manifest (with
	     SupportsMultipleScenes = true) is used instead of the
	     generator's default, which sets it to false. -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
</dict>
</plist>
